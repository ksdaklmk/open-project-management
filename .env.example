# Browser-safe Supabase project settings. Never put the service-role key here.
# Local defaults are printed by `supabase status` after the stack is running.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# Production builds should inject the hosted project's HTTPS API URL and anon
# publishable key through the deployment platform, not a committed env file.
